# Database
DATABASE_URL=postgresql://user:password@localhost:5432/ghost_investor_ai

# API Keys - Enrichment
APOLLO_API_KEY=your_apollo_api_key_here
CLEARBIT_API_KEY=your_clearbit_api_key_here
PEOPLE_DATA_LABS_API_KEY=your_people_data_labs_api_key_here

# LLM
OPENAI_API_KEY=your_openai_api_key_here

# Email Integration - Gmail
GMAIL_CLIENT_ID=your_gmail_client_id_here.apps.googleusercontent.com
GMAIL_CLIENT_SECRET=your_gmail_client_secret_here
GOOGLE_CREDENTIALS_JSON=credentials.json

# Email Integration - Outlook
OUTLOOK_CLIENT_ID=your_outlook_client_id_here
OUTLOOK_CLIENT_SECRET=your_outlook_client_secret_here

# CRM Integration
GHOSTCRM_API_KEY=dummy_key
GHOSTCRM_BASE_URL=http://localhost:9999

# LinkedIn (optional)
LINKEDIN_API_KEY=

# JWT Authentication
JWT_SECRET_KEY=your-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# Rate Limiting
RATE_LIMIT_EMAIL_PER_HOUR=50
RATE_LIMIT_UNIQUE_RECIPIENTS_PER_DAY=500

# Celery & Redis
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND_URL=redis://localhost:6379/1

# App Config
ENVIRONMENT=development
DEBUG=True
LOG_LEVEL=INFO

