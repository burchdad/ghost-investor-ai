# Database
DATABASE_URL=postgresql://user:password@localhost:5432/ghost_investor_ai

# API Keys - Enrichment
APOLLO_API_KEY=
CLEARBIT_API_KEY=
PEOPLE_DATA_LABS_API_KEY=

# LLM
OPENAI_API_KEY=

# Email Integration - Gmail
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GOOGLE_CREDENTIALS_JSON=credentials.json

# Email Integration - Outlook
OUTLOOK_CLIENT_ID=
OUTLOOK_CLIENT_SECRET=

# CRM Integration
GHOSTCRM_API_KEY=
GHOSTCRM_BASE_URL=

# LinkedIn (optional)
LINKEDIN_API_KEY=

# JWT Authentication
JWT_SECRET_KEY=your-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# Rate Limiting
RATE_LIMIT_EMAIL_PER_HOUR=50
RATE_LIMIT_UNIQUE_RECIPIENTS_PER_DAY=500

# Celery & Redis
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND_URL=redis://localhost:6379/1

# App Config
ENVIRONMENT=development
DEBUG=True
LOG_LEVEL=INFO

